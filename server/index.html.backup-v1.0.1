<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>墨</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0c1014;
  --panel: rgba(14, 20, 26, 0.9);
  --line: rgba(100, 140, 150, 0.12);
  --line-light: rgba(100, 140, 150, 0.06);
  --text: #d0dcdd;
  --text-muted: #7a9094;
  --text-dim: #506064;
  --accent: #6a9090;
  --accent-light: #8ab0b0;
}

body {
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', Georgia, serif;
  background: var(--bg);
  color: var(--text);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 天青光晕 */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse at 30% 0%, rgba(80, 120, 130, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 100%, rgba(60, 100, 110, 0.08) 0%, transparent 50%);
}

/* 顶部 */
#topbar {
  padding: 16px 32px;
  display: flex;
  align-items: center;
  gap: 24px;
  flex-shrink: 0;
}

#topbar h1 {
  font-size: 16px;
  font-weight: 400;
  color: var(--text);
  letter-spacing: 0.4em;
}

.status {
  display: flex;
  align-items: center;
  gap: 6px;
}

.dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--text-dim);
}

.dot.ok { background: var(--accent); }

.status span {
  font-size: 11px;
  color: var(--text-dim);
}

/* Tab */
.tab-nav {
  display: flex;
  gap: 2px;
}

.tab-btn {
  background: transparent;
  border: none;
  color: var(--text-muted);
  font-size: 13px;
  font-family: inherit;
  padding: 8px 16px;
  cursor: pointer;
  transition: color 0.2s;
}

.tab-btn:hover { color: var(--text); }
.tab-btn.active { color: var(--text); }

/* 主区域 */
#main {
  flex: 1;
  display: flex;
  overflow: hidden;
  padding: 0 32px 24px;
}

/* 侧边栏 */
#sidebar {
  width: 240px;
  flex-shrink: 0;
  padding-right: 24px;
  overflow-y: auto;
}

.section-title {
  font-size: 10px;
  color: var(--text-dim);
  letter-spacing: 0.15em;
  margin-bottom: 12px;
  font-weight: 400;
}

#model-list {
  list-style: none;
  margin-bottom: 32px;
}

#model-list li {
  padding: 10px 0;
  font-size: 13px;
  color: var(--text-muted);
  cursor: pointer;
  border-bottom: 1px solid var(--line-light);
  transition: color 0.2s;
}

#model-list li:last-child { border-bottom: none; }
#model-list li:hover { color: var(--text); }
#model-list li.selected { color: var(--accent-light); }

#selected-model {
  font-size: 11px;
  color: var(--text-dim);
  margin-bottom: 24px;
}

#system-prompt {
  width: 100%;
  height: 80px;
  resize: none;
  font-size: 13px;
  font-family: inherit;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--line-light);
  color: var(--text);
  outline: none;
  margin-bottom: 24px;
}

#system-prompt::placeholder { color: var(--text-dim); }

.param-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.param-row label {
  font-size: 12px;
  color: var(--text-dim);
  width: 48px;
}

.param-row input[type="range"] {
  flex: 1;
  accent-color: var(--accent);
}

.param-row span {
  font-size: 12px;
  color: var(--text-muted);
  width: 32px;
}

/* 聊天区 */
#chat-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

#messages {
  flex: 1;
  overflow-y: auto;
  padding: 24px 0;
}

.msg {
  max-width: 680px;
  margin-bottom: 24px;
}

.msg.user { margin-left: auto; }

.msg-role {
  font-size: 10px;
  color: var(--text-dim);
  letter-spacing: 0.1em;
  margin-bottom: 6px;
}

.msg.user .msg-role { text-align: right; }

.msg-body {
  font-size: 14px;
  line-height: 1.9;
  color: var(--text);
  padding: 12px 0;
  border-bottom: 1px solid var(--line-light);
}

.msg.user .msg-body {
  color: var(--text-muted);
  text-align: right;
  border-bottom: none;
  padding-top: 0;
}

/* 输入区 */
#input-bar {
  padding: 16px 0 0;
  display: flex;
  gap: 12px;
  align-items: flex-end;
}

#user-input {
  flex: 1;
  height: 56px;
  resize: none;
  font-size: 14px;
  font-family: inherit;
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--line);
  color: var(--text);
  outline: none;
}

#user-input::placeholder { color: var(--text-dim); }
#user-input:focus { border-color: var(--accent); }

#send-btn {
  background: transparent;
  border: 1px solid var(--line);
  color: var(--text-muted);
  font-size: 14px;
  padding: 8px 16px;
  cursor: pointer;
  transition: all 0.2s;
  font-family: inherit;
}

#send-btn:hover {
  border-color: var(--accent);
  color: var(--accent-light);
}

/* 按钮 */
button {
  background: transparent;
  border: none;
  color: var(--text-dim);
  font-size: 12px;
  font-family: inherit;
  cursor: pointer;
  padding: 4px 8px;
}

button:hover { color: var(--text); }

/* Tab 内容 */
.tab-panel { display: none; flex: 1; overflow: hidden; }
.tab-panel.active { display: flex; }
#chat-panel.chat-tab { display: flex; }
#chat-panel:not(.chat-tab) { display: none; }

#prompts-tab, #materials-tab {
  padding: 24px 0;
}

#prompts-tab .content,
#materials-tab .content {
  flex: 1;
  overflow-y: auto;
}

.item {
  padding: 16px 0;
  border-bottom: 1px solid var(--line-light);
  cursor: pointer;
}

.item-title { font-size: 14px; color: var(--text); margin-bottom: 4px; }
.item-meta { font-size: 11px; color: var(--text-dim); }

/* 滚动条 */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--line); border-radius: 2px; }

/* 隐藏 */
.hidden { display: none !important; }
</style>
</head>
<body>

<div id="topbar">
  <h1>墨</h1>
  <div class="status">
    <div class="dot" id="status-dot"></div>
    <span id="status-text">待连接</span>
  </div>
  <div style="flex:1"></div>
  <div class="tab-nav">
    <button class="tab-btn active" data-tab="chat" onclick="switchTab('chat')">对话</button>
    <button class="tab-btn" data-tab="prompts" onclick="switchTab('prompts')">词稿</button>
    <button class="tab-btn" data-tab="materials" onclick="switchTab('materials')">素材</button>
  </div>
  <div style="flex:1"></div>
  <button onclick="exportMarkdown()">导出</button>
</div>

<div id="main">

  <!-- 侧边栏 -->
  <div id="sidebar">
    <div class="section-title">模型</div>
    <ul id="model-list"><li>加载中…</li></ul>
    <div id="selected-model"></div>

    <div class="section-title">系统词</div>
    <textarea id="system-prompt" placeholder="（可留空）"></textarea>

    <div class="section-title">参数</div>
    <div class="param-row">
      <label>温度</label>
      <input type="range" id="temp-slider" min="0" max="2" step="0.1" value="0.7">
      <span id="temp-val">0.7</span>
    </div>
  </div>

  <!-- 对话 -->
  <div id="chat-panel" class="chat-tab">
    <div id="messages">
      <div class="msg assistant">
        <div class="msg-role">墨</div>
        <div class="msg-body">请先选择一个模型，开始对话。</div>
      </div>
    </div>
    <div id="input-bar">
      <textarea id="user-input" placeholder="在此书写…" onkeydown="onKeyDown(event)"></textarea>
      <button id="send-btn" onclick="handleSendBtn()">发送</button>
    </div>
  </div>

  <!-- 词稿 -->
  <div id="prompts-tab" class="tab-panel">
    <div class="content" id="prompts-list">加载中…</div>
  </div>

  <!-- 素材 -->
  <div id="materials-tab" class="tab-panel">
    <div class="content" id="materials-list">加载中…</div>
  </div>

</div>

<script>
const messages = document.getElementById('messages');
const userInput = document.getElementById('user-input');
const sendBtn = document.getElementById('send-btn');
const modelList = document.getElementById('model-list');
const systemPrompt = document.getElementById('system-prompt');
const tempSlider = document.getElementById('temp-slider');
const tempVal = document.getElementById('temp-val');
const statusDot = document.getElementById('status-dot');
const statusText = document.getElementById('status-text');
const selectedModelDiv = document.getElementById('selected-model');

let allModels = [];
let selectedModelId = null;
let chatHistory = [];
let abortController = null;
let isStreaming = false;

document.addEventListener('DOMContentLoaded', init);

async function init() {
  loadConfig();
  loadModels();
  checkApiStatus();
}

function loadConfig() {
  fetch('/config').then(r => r.json()).then(c => {
    systemPrompt.value = localStorage.getItem('systemPrompt') || '';
    tempSlider.value = localStorage.getItem('temperature') || '0.7';
    tempVal.textContent = parseFloat(tempSlider.value).toFixed(1);
  });
  tempSlider.oninput = () => tempVal.textContent = parseFloat(tempSlider.value).toFixed(1);
}

async function checkApiStatus() {
  try {
    const res = await fetch('/models');
    if (res.ok) {
      statusDot.className = 'dot ok';
      statusText.textContent = '已连接';
    }
  } catch {
    statusText.textContent = '未连接';
  }
}

async function loadModels() {
  try {
    const res = await fetch('/models/all');
    const data = await res.json();
    allModels = [];
    for (const src of data.sources || []) {
      for (const m of src.models || []) {
        allModels.push({ id: m.id, name: m.displayName || m.id, platform: src.sourceName });
      }
    }
    renderModels();
  } catch {
    modelList.innerHTML = '<li>加载失败</li>';
  }
}

function renderModels() {
  modelList.innerHTML = allModels.map(m => `
    <li onclick="selectModel('${m.id}')" class="${m.id === selectedModelId ? 'selected' : ''}">
      ${m.name}
    </li>
  `).join('') || '<li>无模型</li>';
}

function selectModel(id) {
  selectedModelId = id;
  const m = allModels.find(x => x.id === id);
  selectedModelDiv.textContent = m ? `${m.name} · ${m.platform}` : id;
  renderModels();
}

function renderMessages() {
  messages.innerHTML = chatHistory.map(m => `
    <div class="msg ${m.role === 'user' ? 'user' : 'assistant'}">
      <div class="msg-role">${m.role === 'user' ? '吾' : '墨'}</div>
      <div class="msg-body">${escapeHtml(m.content)}</div>
    </div>
  `).join('');
  messages.scrollTop = messages.scrollHeight;
}

async function sendMessage() {
  const content = userInput.value.trim();
  if (!content) return;
  if (!selectedModelId) {
    chatHistory.push({ role: 'assistant', content: '请先选择一个模型。' });
    renderMessages();
    return;
  }

  chatHistory.push({ role: 'user', content });
  userInput.value = '';
  renderMessages();

  const msgs = [...chatHistory];
  const system = systemPrompt.value.trim();
  if (system) msgs.unshift({ role: 'system', content: system });

  const payload = {
    model: selectedModelId,
    messages: msgs,
    temperature: parseFloat(tempSlider.value)
  };

  localStorage.setItem('systemPrompt', systemPrompt.value);
  localStorage.setItem('temperature', tempSlider.value);

  const msgDiv = document.createElement('div');
  msgDiv.className = 'msg assistant';
  msgDiv.innerHTML = `<div class="msg-role">墨</div><div class="msg-body"></div>`;
  messages.appendChild(msgDiv);
  const bodyEl = msgDiv.querySelector('.msg-body');

  sendBtn.textContent = '■';
  abortController = new AbortController();
  isStreaming = true;

  try {
    const res = await fetch('/chat/stream', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
      signal: abortController.signal
    });

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let fullContent = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      const chunk = decoder.decode(value);
      for (const line of chunk.split('\n')) {
        if (line.startsWith('data: ')) {
          const data = line.slice(6).trim();
          if (data === '[DONE]') continue;
          try {
            const j = JSON.parse(data);
            const c = j.choices?.[0]?.delta?.content;
            if (c) {
              fullContent += c;
              bodyEl.textContent = fullContent;
              messages.scrollTop = messages.scrollHeight;
            }
          } catch {}
        }
      }
    }

    chatHistory.push({ role: 'assistant', content: fullContent });
  } catch (e) {
    if (e.name !== 'AbortError') {
      bodyEl.textContent = '错误：' + e.message;
    }
  }

  abortController = null;
  isStreaming = false;
  sendBtn.textContent = '发送';
  messages.scrollTop = messages.scrollHeight;
}

function handleSendBtn() {
  if (isStreaming) {
    abortController?.abort();
  } else {
    sendMessage();
  }
}

function onKeyDown(e) {
  if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
    e.preventDefault();
    handleSendBtn();
  }
}

function escapeHtml(text) {
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function exportMarkdown() {
  if (!chatHistory.length) return;
  const md = chatHistory.map(m => `**${m.role === 'user' ? '吾' : '墨'}**\n\n${m.content}`).join('\n\n---\n\n');
  const blob = new Blob(['# 对话记录\n\n' + md], { type: 'text/markdown' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `对话_${Date.now()}.md`;
  a.click();
}

// Tab
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.toggle('active', p.id === `${tab}-tab`));
  const chatPanel = document.getElementById('chat-panel');
  chatPanel.classList.toggle('chat-tab', tab === 'chat');
  if (tab === 'prompts') loadPrompts();
  if (tab === 'materials') loadMaterials();
}

async function loadPrompts() {
  const res = await fetch('/prompts/v2');
  const data = await res.json();
  document.getElementById('prompts-list').innerHTML = (data.prompts || []).map(p => `
    <div class="item" onclick="applyPrompt('${p.id}')">
      <div class="item-title">${escapeHtml(p.name)}</div>
      <div class="item-meta">v${p.version} · ${(p.content || '').slice(0, 50)}…</div>
    </div>
  `).join('') || '<div class="item-meta">暂无词稿</div>';
}

function applyPrompt(id) {
  fetch(`/prompts/v2/${id}`).then(r => r.json()).then(p => {
    systemPrompt.value = p.content;
    switchTab('chat');
  });
}

async function loadMaterials() {
  const res = await fetch('/materials');
  const data = await res.json();
  document.getElementById('materials-list').innerHTML = (data.materials || []).map(m => `
    <div class="item">
      <div class="item-title">${escapeHtml(m.title)}</div>
      <div class="item-meta">${escapeHtml(m.summary || '')}</div>
    </div>
  `).join('') || '<div class="item-meta">暂无素材</div>';
}
</script>
</body>
</html>